<!-- pages/index/index.wxml - 发现页 -->
<view class="container">
  <!-- 页面标题 -->
  <view class="page-header">
    <view class="page-title">发现</view>
    <view class="page-subtitle">最新学术论文 · 智能推荐</view>
  </view>

  <!-- 快捷搜索入口 -->
  <view class="search-box" bindtap="goToSearch">
    <text class="search-icon">🔍</text>
    <input placeholder="搜索论文标题、作者、关键词..." disabled />
  </view>

  <!-- 内容切换 Tab -->
  <view class="segment-control">
    <view class="segment-item {{activeTab === 'trending' ? 'active' : ''}}" bindtap="switchTab" data-tab="trending">
      🔥 热门
    </view>
    <view class="segment-item {{activeTab === 'latest' ? 'active' : ''}}" bindtap="switchTab" data-tab="latest">
      ⚡ 最新
    </view>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-container">
    <view class="skeleton" style="height: 200rpx; margin-bottom: 20rpx;"></view>
    <view class="skeleton" style="height: 200rpx; margin-bottom: 20rpx;"></view>
    <view class="skeleton" style="height: 200rpx;"></view>
  </view>

  <!-- 论文列表 -->
  <view wx:elif="{{papers.length > 0}}">
    <view wx:for="{{papers}}" wx:key="id" class="paper-card" bindtap="goToPaper" data-id="{{item.id}}">
      <view class="paper-card-header">
        <view class="journal-dot" style="background: {{item.color}};"></view>
        <view class="journal-label">{{item.journal_name || '未分类'}}</view>
        <view class="journal-label" style="margin-left: auto; color: #cbd5e1;">Vol {{item.volume || '-'}}</view>
      </view>
      <view class="paper-card-title">{{item.title}}</view>
      <view wx:if="{{item.abstract}}" class="paper-card-abstract">{{item.abstract}}</view>
      <view wx:if="{{item.authors}}" class="paper-card-authors">{{item.authors}}</view>
      <view class="paper-card-footer">
        <view class="paper-card-date">{{item.date_display}}</view>
        <view class="paper-card-meta">
          <view class="meta-item">📄 {{item.citation_count || 0}} 引用</view>
        </view>
      </view>
    </view>

    <!-- 加载更多 -->
    <view wx:if="{{hasMore}}" class="loading-container" style="padding: 40rpx 0;">
      <view class="loading-text" bindtap="loadMore">点击加载更多</view>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:else class="empty-state">
    <view class="empty-icon">📚</view>
    <view class="empty-text">暂无论文</view>
    <view class="empty-subtext">稍后再来看看吧</view>
  </view>
</view>