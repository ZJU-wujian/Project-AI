/* pages/paper/paper.wxss - 论文详情页样式 */

.paper-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 32rpx;
  flex-wrap: wrap;
}

.journal-tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  color: white;
  font-size: 24rpx;
  font-weight: 600;
}

.vol-tag {
  background: #f1f5f9;
  color: #64748b;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.paper-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #0f172a;
  line-height: 1.4;
  margin-bottom: 20rpx;
}

.paper-authors {
  font-size: 28rpx;
  color: #64748b;
  margin-bottom: 16rpx;
  line-height: 1.6;
}

.paper-date {
  font-size: 26rpx;
  color: #94a3b8;
  margin-bottom: 24rpx;
}

.paper-meta-row {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
  margin-bottom: 24rpx;
}

.meta-pill {
  background: #f1f5f9;
  color: #475569;
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.paper-section {
  margin-bottom: 40rpx;
}

.section-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #0f172a;
  margin-bottom: 16rpx;
}

.paper-abstract {
  font-size: 28rpx;
  color: #475569;
  line-height: 1.8;
}

.keyword-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.keyword-item {
  background: #dbeafe;
  color: #1d4ed8;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.paper-doi {
  font-size: 26rpx;
  color: #64748b;
  font-family: monospace;
  word-break: break-all;
  background: #f8fafc;
  padding: 16rpx;
  border-radius: 12rpx;
}

.similar-card {
  background: #f8fafc;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  transition: all 0.2s;
}

.similar-card:active {
  background: #e2e8f0;
}

.similar-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.similar-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #0f172a;
  line-height: 1.4;
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.similar-meta {
  font-size: 24rpx;
  color: #94a3b8;
}

.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  padding: 20rpx 24rpx;
  display: flex;
  gap: 20rpx;
  border-top: 2rpx solid #e2e8f0;
}

.bottom-actions .btn {
  flex: 1;
  padding: 24rpx 0;
  font-size: 28rpx;
  border-radius: 16rpx;
}

.container {
  padding-bottom: 180rpx;
}